  "sections": [
    {
      "name": "Prematch",
      "fields": [
        {
          "title": "Scouter Initials",
          "description": "Enter the initials of the scouter.",
          "type": "text",
          "required": true,
          "code": "scouter",
          "formResetBehavior": "preserve",
          "defaultValue": ""
        },
        {
        "title": "Match Number",
        "type": "TBA-match-number",
        "required": true,
        "code": "matchNumber",
        "description": "Select qualification match number",
        "formResetBehavior": "increment",
        "defaultValue": 1,
        "min": 1,
        "max": 100
        },
        {
        "title": "Team & Robot Position",
        "type": "TBA-team-and-robot",
        "required": false,
        "code": "teamAndRobot",
        "description": "Select team and robot position",
        "formResetBehavior": "reset",
        "defaultValue": null
        },
        {
          "title": "Starting Position",
          "description": "The starting position of the robot.",
          "type": "select",
          "required": false,
          "code": "startPos",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "OT": "Outpost Trench",
            "OBFT": "Outpost Bump",
            "H": "Hub",
            "DBFT": "Depot Bump",
            "DT": "Depot Trench"
          }
        },
        {
          "title": "No Show",
          "description": "Check if the robot did not show up for the match.",
          "type": "boolean",
          "required": false,
          "code": "noShow",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Game Play",
      "fields": [
        {
          "title": "Autonomous Cycles",
          "description": "What did the robot do during autonomous?",
          "type": "select",
          "required": false,
          "code": "autoCycle",
          "formResetBehavior": "reset",
          "defaultValue": "Notshomo",
          "choices": {
            "ShootNeutral": "Shoot then Neutral Zone",
            "NeutralShoot": "Neutral Zone then Shoot",
            "TwoCycles": "Two Cycles",
            "ThreeCycles": "Three Cycles",
            "NoCycle": "No Cycle"
          }
        },
        {
          "title": "Auto End Position",
          "description": "Where they ended on the field at the end of Autonomous?",
          "type": "select",
          "required": false,
          "code": "autoEndPos",
          "formResetBehavior": "reset",
          "defaultValue": "Hub",
          "choices": {
            "Hub": "Hub",
            "Depot": "Depot",
            "Outpost": "Outpost"
          }
        },     
        {
          "title": "Scoring Acc. in Auto?",
          "description": "The percentage accuracy for the number of fuel scored in autonomous.",
          "type": "select",
          "required": false,
          "code": "autoFuelScored",
          "formResetBehavior": "reset",
          "defaultValue": "0",
          "choices": {
            "0": "🟥 0%-25%",
            "25": "🟧 25%-50%",
            "50": "🟨 50%-75%",
            "75": "🟩 75%-100%"
      },
      {
      "title": "Active Shift: Role",
      "type": "select",
      "required": false,
      "code": "Shift_Active_role",
      "formResetBehavior": "reset",
      "defaultValue": "No Role",
      "choices": {
        "No Role": "None",
        "Shoot": "Shooter",
        "Shuttle": "Shuttler",
        "Pass": "Passer",
        "Defend": "Defender"
            }
      },
      {
      "title": "Inactive Shift: Role",
      "type": "select",
      "required": false,
      "code": "Shift_Inactive_role",
      "formResetBehavior": "reset",
      "defaultValue": "No Role",
      "choices": {
        "No Role": "None",
        "Shuttle": "Shuttler",
        "Pass": "Passer",
        "Defend": "Defender"
      }
    },
    {
      "title": "Active/InActive Shift: Fuel Movement",
      "type": "select",
      "required": false,
      "code": "Shift_fuelMov",
      "formResetBehavior": "reset",
      "defaultValue": "0",
      "choices": {
      "0": "🟥 None — No meaningful fuel interaction",
      "1": "🟧 Minimal — Very little or accidental fuel movement",
      "2": "🟨 Support — Moves fuel sometimes but not a main role",
      "3": "🟩 Active — Regularly collecting and transporting fuel",
      "4": "🟦 Elite — Main fuel supplier for alliance"
      }
    },
    {
      "title": "Active/InActive Shift: Fuel Influence",
      "type": "select",
      "required": false,
      "code": "Shift_fuelInflu",
      "formResetBehavior": "reset",
      "defaultValue": "0",
      "choices": {
      "0": "🟥 None — No fuel impact",
      "1": "🟧 Minor — Small fuel influence",
      "2": "🟨 Moderate — Controls some fuel areas",
      "3": "🟩 Major — Strong fuel control"
        }
    }
  ]
},
