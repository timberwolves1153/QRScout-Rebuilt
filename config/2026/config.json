          "choices": {
            "Hub": "Hub",
            "Depot": "Depot",
            "Outpost": "Outpost",
            "Tren": "Trench",
            "Neu": "Neutral Zone",
            "Oppo": "Opponent's Zone",
            "Other": "Other spots (Middle area of own alliance zone)"
