          "type": "select",
          "required": true,
          "code": "ActiveRole",
          "formResetBehavior": "reset",
          "defaultValue": "No Role",
          "choices": {
            "No Role": "None",
            "Score": "Scorer",
            "Shoot": "Shooter",
            "Shuttle": "Shuttler",
            "Pass": "Passer",
            "Defend": "Defender"
          }
        },
        {
          "title": "Scoring Acc. in Active Shift?",
          "description": "The percentage accuracy for the number of fuel scored in autonomous.",
          "type": "select",
          "required": false,
          "code": "activeFuelScored",
          "formResetBehavior": "reset",
          "defaultValue": "0",
          "choices": {
            "0": "🟥 0%-25%",
            "25": "🟧 25%-50%",
            "50": "🟨 50%-75%",
            "75": "🟩 75%-100%"
          }
        },
        {
          "title": "Defended during Active Shift?",
          "description": "Did the robot play defense during the match?",
          "type": "boolean",
          "required": false,
          "code": "activerobotDefended",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Defense Skill",
          "description": "Rate the robot's defensive skill.",
          "type": "select",
          "required": false,
          "code": "activedefSkill",
          "formResetBehavior": "reset",
          "defaultValue": "1",
